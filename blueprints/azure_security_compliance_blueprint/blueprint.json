      },
      {
        "type": "policyAssignment",
        "name": "keyvault-purge-protection",
        "path": "artifacts/policy-assignment-keyvault-purge-protection.json"
      },
      {
        "type": "policyAssignment",
        "name": "storage-public-access",
        "path": "artifacts/policy-assignment-storage-public-access.json"
      },
      {
        "type": "policyAssignment",
        "name": "allowed-locations",
        "path": "artifacts/policy-assignment-allowed-locations.json"
      },
      {
        "type": "policyAssignment",
        "name": "required-tags",
        "path": "artifacts/policy-assignment-required-tags.json"
