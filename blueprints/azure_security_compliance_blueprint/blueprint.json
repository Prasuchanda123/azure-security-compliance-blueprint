{
  "properties": {
    "description": "Security Compliance Blueprint",
    "targetScope": "subscription",
    "parameters": {
      "allowedLocations": {
        "type": "array",
        "metadata": {
          "displayName": "Allowed Azure Locations"
        }
      },
      "requiredTags": {
        "type": "object",
        "metadata": {
          "displayName": "Required Tags"
        }
      }
    },
    "resourceGroups": {
